# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do Backend Dualingo
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# Porta do servidor local (padrão: 3001)
PORT=3001

# Chave secreta para JWT local (NÃO usar em produção)
JWT_SECRET=dualingo-local-dev-secret-2024

# ── AWS (apenas para deploy em produção) ──────────────────────────────────────
# COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
