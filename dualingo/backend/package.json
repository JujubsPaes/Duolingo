{
  "name": "dualingo-backend",
  "version": "1.0.0",
  "description": "Backend serverless do Dualingo — AWS Lambda + DynamoDB + Cognito",
  "scripts": {
    "build": "tsc",
    "dev": "serverless offline",
    "dev:local": "ts-node src/local/server.ts",
    "dev:watch": "ts-node-dev --respawn src/local/server.ts",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "seed": "ts-node src/seed/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.6.0",
    "serverless-plugin-typescript": "^2.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
